          }
        }
      }
    },
    "Local Voice is fully offline. No data can leave your device.": {
      "comment": "Text displayed in a warning banner at the top of the screen when the user is not a member.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Local Voice полностью отключен от сети. Никакие данные не могут покинуть ваше устройство."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Local Voice повністю офлайн. Дані не можуть залишити ваш пристрій."
          }
        }
      }
    },
    "Local Voice is getting ready.": {
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Local Voice готовится к записи."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Local Voice готується до запису."
          }
        }
      }
    },
    "Local Voice is open source and cannot make network connections. Audio, transcripts, and settings remain on this Mac.": {
      "comment": "A description of how Local Voice collects and uses user data.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Local Voice имеет открытый исходный код и не может устанавливать сетевые подключения. Аудио, расшифровки и настройки остаются на этом Mac."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Local Voice є відкритим вихідним кодом і не може підключатися до мережі. Аудіо, стенограми та налаштування залишаються на цьому Mac."
          }
        }
      }
    },
    "Local Voice is processing": {
      "comment": "Tooltip for the status item when Local Voice is processing.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "ru": {
          "stringUnit": {
